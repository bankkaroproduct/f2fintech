# F2 Fintech Partner Configuration
# Copy to .env.local or set in Vercel dashboard

NEXT_PUBLIC_BRAND_NAME=F2 Fintech
NEXT_PUBLIC_BRAND_TAGLINE=Instant Personal & Business Loans | Fast Approval India
NEXT_PUBLIC_BRAND_LOGO=/f2fintech-logo.png
NEXT_PUBLIC_BRAND_FAVICON=/f2fintech-favicon.png
NEXT_PUBLIC_BRAND_EMAIL=support@f2fintech.com

# Colors (F2 Fintech Blue)
NEXT_PUBLIC_PRIMARY_COLOR=#3A49D6
NEXT_PUBLIC_SECONDARY_COLOR=#F4FAFF
NEXT_PUBLIC_HEADER_BG_COLOR=#3A49D6

# HSL fallbacks
NEXT_PUBLIC_PRIMARY_HUE=234
NEXT_PUBLIC_PRIMARY_SAT=66%
NEXT_PUBLIC_PRIMARY_LIGHT=53%
NEXT_PUBLIC_SECONDARY_HUE=213
NEXT_PUBLIC_SECONDARY_SAT=100%
NEXT_PUBLIC_SECONDARY_LIGHT=97%

# App URL
NEXT_PUBLIC_APP_URL=https://f2fintech.com

# Analytics (set your GA ID)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# API Keys (set in deployment)
# PARTNER_API_KEY=your-api-key
# PARTNER_TOKEN_URL=https://platform.bankkaro.com/partner/token
# PARTNER_BASE_URL=https://platform.bankkaro.com/partner
